# EditorConfig — REQ-FND-001 AC-05 (consistent indent/charset/final-newline)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python (Flask API module) — PEP 8: 4 spaces
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript / JSON / CSS (React 19 SPA module) — 2 spaces
[*.{ts,tsx,js,jsx,mjs,cjs,json,css,html}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
